# --- Данные для работы агента.
PORT=40400
API_KEY=
PROXY=
DEEPSEEK=


DISPLAY=:101
BROWSE_URL=http://127.0.0.1:40401
BROWSE_PORT=40401


# --- PROXY  ---
PROXY_HOST=
PROXY_HTTP_PORT=
PROXY_USERNAME=
PROXY_PASSWORD=
PROXY_KIND=http
BROWSER_USE_PROXY=0


# --- Браузер ---
BROWSER_WINDOW_W=1200
BROWSER_WINDOW_H=913
BROWSER_CHANNEL=msedge
BROWSER_USER_DATA_DIR=/data/browser_profiles/agent1_brw


# ----- Управление запуском --------
NAV_TIMEOUT_MS=90000
NAV_WAIT_UNTIL=domcontentloaded
BROWSER_PERSISTENT=0
BROWSER_BIN=/usr/bin/microsoft-edge-stable
CHROME_BIN=/usr/bin/microsoft-edge-stable
CDP_BROWSER=msedge
BROWSER_CONNECT_CDP=1
BROWSER_MODE=launch
CDP_URL=http://127.0.0.1:9222
BROWSER_WINDOW_X=0
BROWSER_WINDOW_Y=0

# Поднимаем сами при запуске браузер? 1-да/ 0-нет
CDP_SPAWN_BROWSER=1
# закрывать ли Edge при stop()? 1-да/ 0-нет
CDP_KILL_ON_STOP=1
